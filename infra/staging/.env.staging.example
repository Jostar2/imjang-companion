COMPOSE_PROJECT_NAME=imjang-staging

API_IMAGE=ghcr.io/example/imjang-api:staging
WEB_IMAGE=ghcr.io/example/imjang-web:staging

API_PORT=8000
WEB_PORT=3000

DATABASE_URL=postgresql+psycopg://imjang:imjang@postgres:5432/imjang
POSTGRES_DB=imjang
POSTGRES_USER=imjang
POSTGRES_PASSWORD=change-me

STORAGE_BACKEND=s3
S3_ENDPOINT=http://minio:9000
S3_BUCKET=imjang-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me
S3_REGION=ap-northeast-2

WEB_ORIGINS=https://staging.example.com
NEXT_PUBLIC_API_BASE_URL=https://staging-api.example.com
ADMIN_EMAILS=admin@example.com
